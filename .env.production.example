# =============================================================================
# AI Workers — Production environment template
# תבנית משתני סביבה לפרודקשן
#
# Copy to Railway Dashboard → Variables (or your host's secret store).
# העתיקו ללוח הבקרה של Railway → Variables (או מאגר הסודות של הספק).
# Never commit real secrets. / לעולם אל תעלו סודות אמיתיים ל-Git.
# =============================================================================

# --- Identity / זהות -------------------------------------------------------
# Display name on landing, invoices, and worker UI.
# שם התצוגה בדף הבית, בחשבוניות ובממשק העובדים.
AGENT_NAME=AI Workers

# One-line tagline for SEO and marketplace header.
# שורת תיאור קצרה ל-SEO ולכותרת המרקטפלייס.
AGENT_DESCRIPTION=AI employees for Israeli businesses

# Canonical public URL — REQUIRED in production (no trailing slash).
# כתובת ציבורית קנונית — חובה בפרודקשן (בלי / בסוף).
# Railway example: https://your-service.up.railway.app
PUBLIC_BASE_URL=https://your-service.up.railway.app

# Support / billing contact shown on invoice and escalation emails.
# איש קשר לתמיכה וחיוב — מופיע בחשבונית ובמיילי הסלמה.
AGENT_OWNER_CONTACT=support@yourdomain.com

# --- LLM runtime / מנוע שפה -----------------------------------------------
# API key for OpenAI, Anthropic, Groq, Ollama gateway, etc.
# מפתח API ל-OpenAI, Anthropic, Groq, שער Ollama וכו'.
LLM_API_KEY=sk-...

# Provider: openai_compatible | anthropic
# ספק: openai_compatible | anthropic
LLM_PROVIDER=openai_compatible

# Model id — e.g. gpt-5.5, claude-sonnet-4-20250514
# מזהה מודל — למשל gpt-5.5, claude-sonnet-4-20250514
LLM_MODEL=gpt-5.5

# Base URL — leave empty for OpenAI default; set for Ollama/Groq/custom.
# כתובת בסיס — ריק לברירת מחדל של OpenAI; מלאו ל-Ollama/Groq/מותאם.
LLM_BASE_URL=

# --- Payment channels / ערוצי תשלום -----------------------------------------
# At least one channel recommended for Israeli buyers.
# מומלץ לפחות ערוץ אחד לקונים בישראל.

# PayPal.Me username (without paypal.me/) — e.g. you → paypal.me/you
# שם משתמש PayPal.Me (בלי paypal.me/)
PAYPAL_ME=your-paypal-username

# Bit mobile number — Israeli format, e.g. 972541234567
# מספר ביט — פורמט ישראלי, למשל 972541234567
BIT_PHONE=972541234567

# Optional additional channels / ערוצים נוספים (אופציונלי)
BUY_ME_A_COFFEE=
KO_FI=
GITHUB_SPONSORS=
GUMROAD_URL=

# --- Bank invoice (Israeli-friendly) / חשבונית בנק --------------------------
PAYEE_NAME=שם העסק / Your Business Ltd
BANK_NAME=Bank Hapoalim
BANK_BRANCH=620
BANK_ACCOUNT=123456
IBAN=
SWIFT=

# --- Admin / ניהול ---------------------------------------------------------
# Long random secret — protects /admin/*, /earnings, key issuance.
# סוד אקראי ארוך — מגן על /admin/*, /earnings והנפקת מפתחות.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=

# --- Server / שרת -----------------------------------------------------------
# Railway sets PORT automatically — do not override unless required.
# Railway מגדיר PORT אוטומטית — אל תדרסו אלא אם חובה.
PORT=8765

RATE_LIMIT_PER_MIN=120
SIGNUP_LIMIT_PER_HOUR=12

# --- Railway persistent volume paths / נתיבי ווליום קבוע ב-Railway ----------
# Mount a volume at /app/data in Railway Dashboard → Service → Volumes.
# חברו ווליום בנתיב /app/data ב-Railway Dashboard → Service → Volumes.
DB_PATH=/app/data/earnings.db
TENANTS_DIR=/app/data/tenants

# REQUIRED on Railway — app sits behind Railway's reverse proxy.
# חובה ב-Railway — האפליקציה מאחורי פרוקסי של Railway.
TRUST_PROXY_HEADERS=1

# --- Trial & payments / ניסיון ותשלומים -----------------------------------
TRIAL_DAYS=14
PAYMENT_AUTO_VERIFY=0
BIT_WEBHOOK_SECRET=
PAYPAL_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_SECRET=
ACTIVATION_SLA_HOURS=24

# --- Embeddable widget / וידג'ט מוטמע --------------------------------------
EMBED_ALLOW_PUBLIC=1
# CORS_ALLOW_ORIGIN=https://your-website.com

# --- Webhooks & integrations / וובהוקים ואינטגרציות -----------------------
# Optional — POST JSON on new leads / escalations.
# אופציונלי — POST JSON על לידים חדשים / הסלמות.
WEBHOOK_NOTIFY_URL=

# Hebrew business hours hint for check_business_hours tool.
# רמז שעות פעילות בעברית לכלי check_business_hours.
# Example: א-ה 09:00-18:00, ו 09:00-13:00
BUSINESS_HOURS=א-ה 09:00-18:00, ו 09:00-13:00

# CORS — leave empty for same-origin; set only for a trusted separate frontend.
# CORS — השאירו ריק לאותו מקור; מלאו רק לפרונטאנד נפרד ומאומת.
CORS_ALLOW_ORIGIN=

# NEVER set to 1 in production — allows fetching localhost/private URLs.
# לעולם אל תגדירו 1 בפרודקשן — מאפשר גישה ל-localhost/רשת פרטית.
ALLOW_PRIVATE_NETWORK_URLS=

# --- Integrations OAuth (platform-level — never in UI/code) ----------------
# Users click "Connect with Google/HubSpot/..." — tokens stored encrypted per tenant.
# Register redirect URI on each provider:
#   https://YOUR_PUBLIC_BASE_URL/api/integrations/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=

# Encrypts per-tenant integration configs in SQLite (generate a long random string).
INTEGRATIONS_SECRET=

# Optional MCP preset server URLs (users connect via button, no paste).
MCP_PRESET_FILESYSTEM_URL=
MCP_PRESET_GITHUB_URL=

# --- WhatsApp (inbound + outbound) / WhatsApp --------------------------------
# See docs/WHATSAPP-ROADMAP.md
WHATSAPP_PROVIDER=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PHONE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
