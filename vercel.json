{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "analytics-client.js",
          "bootstrap-env.js",
          "workers.js",
          "workers-ui.html",
          "assets/**",
          "mcp-client.js",
          "skills.js",
          "docs/legal/**",
          "url-security.js",
          "whatsapp-router.js",
          "whatsapp-webhook.js",
          "payment-webhooks.js",
          "embed-widget.js",
          "integrations/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "env": {
    "NODE_OPTIONS": "--experimental-sqlite --no-warnings",
    "DB_PATH": "/tmp/ai-workers-data/earnings.db",
    "TENANTS_DIR": "/tmp/ai-workers-data/tenants",
    "TRUST_PROXY_HEADERS": "1"
  }
}
