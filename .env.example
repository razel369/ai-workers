# Copy to .env and fill in.

# --- Identity -------------------------------------------------------------
AGENT_NAME=AI Workers
AGENT_DESCRIPTION=AI employees for Israeli businesses
PUBLIC_BASE_URL=http://localhost:8765
AGENT_OWNER_CONTACT=you@example.com

# --- LLM runtime ----------------------------------------------------------
# Required for real AI replies. Leave empty only for local/demo mock mode.
LLM_API_KEY=
LLM_PROVIDER=openai_compatible
LLM_MODEL=gpt-5.5
# OpenRouter free tier example:
#   LLM_API_KEY=sk-or-v1-...
#   LLM_MODEL=openrouter/free
#   LLM_BASE_URL=https://openrouter.ai/api
# (do NOT add /v1 — the app appends /v1/chat/completions automatically)
LLM_BASE_URL=

# --- Google media (image + video) -----------------------------------------
# Get a key: https://aistudio.google.com/apikey (paid tier for image/video)
GOOGLE_AI_API_KEY=
# GEMINI_API_KEY=                    # alias for GOOGLE_AI_API_KEY
GOOGLE_MEDIA_IMAGE_MODEL=gemini-3.1-flash-lite-image
GOOGLE_MEDIA_VIDEO_MODEL=veo-3.1-lite-generate-preview
GOOGLE_MEDIA_VIDEO_MAX_WAIT_MS=90000
MEDIA_GEN_LIMIT_PER_MONTH=50

# --- Payment channels (any combination) -----------------------------------
PAYPAL_ME=
BUY_ME_A_COFFEE=
KO_FI=
BIT_PHONE=
GITHUB_SPONSORS=
GUMROAD_URL=

# --- Bank invoice (Israeli-friendly) --------------------------------------
PAYEE_NAME=
BANK_NAME=
BANK_BRANCH=
BANK_ACCOUNT=
IBAN=
SWIFT=

# --- Admin (issue tenant API keys) ----------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=

# --- Server ---------------------------------------------------------------
PORT=8765
RATE_LIMIT_PER_MIN=120
SIGNUP_LIMIT_PER_HOUR=12
DB_PATH=./data/earnings.db
TENANTS_DIR=./data/tenants

# Set to 1 only when the app is behind a trusted reverse proxy/load balancer
# that overwrites X-Forwarded-* headers. Required on Railway/Vercel production.
TRUST_PROXY_HEADERS=

# Free trial for new workers (days). 0 = disabled. Production pilot: 14
TRIAL_DAYS=0

# Payment auto-activation (see docs/PAYMENTS.md)
PAYMENT_AUTO_VERIFY=
BIT_WEBHOOK_SECRET=
PAYPAL_WEBHOOK_SECRET=
PAYMENT_WEBHOOK_SECRET=
ACTIVATION_SLA_HOURS=24

# Embeddable chat widget (see docs/EMBED-WIDGET.md)
# CORS_ALLOW_ORIGIN=https://your-website.com
EMBED_ALLOW_PUBLIC=1

# Encryption pepper for per-tenant integration credentials (generate random 32+ chars)
INTEGRATIONS_SECRET=

# WhatsApp Business (see docs/WHATSAPP-ROADMAP.md)
WHATSAPP_PROVIDER=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_PHONE_ID=

# Calendar booking fallback link
MEETING_BOOKING_URL=

# Per-tenant integrations encryption (recommended in production).
# Falls back to ADMIN_TOKEN if unset.
INTEGRATIONS_SECRET=

# Default meeting booking link for calendar tools.
MEETING_BOOKING_URL=

# WhatsApp Business (see docs/WHATSAPP-ROADMAP.md)
WHATSAPP_PROVIDER=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Email integrations fallback
EMAIL_WEBHOOK_URL=

# Default business hours hint for check_business_hours tool (optional).
# Example: א-ה 09:00-18:00, ו 09:00-13:00
BUSINESS_HOURS=

# Optional. Leave empty for same-origin only. Set only if a separate trusted
# frontend origin must call this API, e.g. https://app.example.com.
CORS_ALLOW_ORIGIN=

# Keep unset in production. Set to 1 only in isolated local labs when testing
# MCP servers or website learning against localhost/private-network URLs.
ALLOW_PRIVATE_NETWORK_URLS=
