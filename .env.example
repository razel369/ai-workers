# Copy to .env and fill in.

# --- Identity -------------------------------------------------------------
AGENT_NAME=Paid Agent Demo
AGENT_DESCRIPTION=AI agent with x402 and oldschool payment options
AGENT_VERSION=0.4.0
PUBLIC_BASE_URL=http://localhost:3000
AGENT_OWNER_CONTACT=you@example.com

# --- x402 / USDC (crypto, for AI agents) ---------------------------------
NETWORK=base-sepolia
WALLET_ADDRESS=
PRICE_USDC=0.05
FACILITATOR_URL=

# --- Oldschool channels (any combination; zero business needed) -----------
PAYPAL_ME=
BUY_ME_A_COFFEE=
KO_FI=
BIT_PHONE=
GITHUB_SPONSORS=
GUMROAD_URL=

# --- Bank invoice (Israeli-friendly) --------------------------------------
PAYEE_NAME=
BANK_NAME=
BANK_BRANCH=
BANK_ACCOUNT=
IBAN=
SWIFT=

# --- Admin (issue API keys after off-platform payment) --------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=

# --- Server ---------------------------------------------------------------
PORT=3000
RATE_LIMIT_PER_MIN=120
DB_PATH=./data/earnings.db
