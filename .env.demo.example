# העתק לקובץ .env לפני הרצת הדגמת כלים מלאה:
#   Copy-Item .env.demo.example .env
# ואז מלא את הערכים למטה.

# --- חובה לסוכן AI אמיתי (Railway / local עם LLM) ---
# בלי מפתח — המערכת רצה במצב mock (טוב ל-Vercel ולבדיקות UI).
LLM_API_KEY=

# ספק ברירת מחדל — OpenAI-compatible (Cursor, OpenRouter, וכו')
LLM_PROVIDER=openai_compatible
# OpenRouter free tier (tool-capable router): openrouter/free
# Pinned free alternatives: openai/gpt-oss-120b:free, nex-agi/nex-n2-pro:free, meta-llama/llama-3.2-3b-instruct:free
LLM_MODEL=openrouter/free
# Base URL without /v1 — app calls /v1/chat/completions
LLM_BASE_URL=https://openrouter.ai/api

# --- חובה לניהול (אישור תשלום, mark-paid) ---
# צור ערך אקראי: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_TOKEN=

# --- מומלץ לדגמת כלים ---
# webhook.site — צור כתובת ייחודית וראה JSON של save_lead / escalate בזמן אמת
WEBHOOK_NOTIFY_URL=https://webhook.site/your-unique-id

# קישור קביעת פגישות — משמש את book_meeting_link
MEETING_BOOKING_URL=https://cal.com/your-link

# --- אופציונלי: תמונות AI (generate_image) ---
# מפתח מ-Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# --- ניסיון חינם — עובדים חדשים פעילים מיד ל-14 יום ---
TRIAL_DAYS=14

# --- שרת מקומי ---
PORT=8765
PUBLIC_BASE_URL=http://localhost:8765

# ערוץ תשלום לדוגמה (אופציונלי ל-UI paywall)
BIT_PHONE=972541234567
